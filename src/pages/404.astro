---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <div class="flex min-h-[60vh] flex-col items-center justify-center gap-6 text-center">
    <p class="select-none text-8xl font-black text-accent opacity-20">404</p>
    <div>
      <h1 class="mb-2 text-2xl font-bold text-gray-900">Page Not Found</h1>
      <p class="text-gray-500">The page you're looking for doesn't exist or has moved.</p>
    </div>
    <a
      href="/"
      class="rounded-xl bg-accent px-5 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-accent-600"
    >
      Go Home
    </a>
  </div>
</BaseLayout>
