---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { site } from '../config';

const contacts = [
  {
    label: 'GitHub',
    href: site.socials.find((s) => s.kind === 'github')?.href ?? '#',
    icon: 'lucide:github',
  },
  {
    label: 'LinkedIn',
    href: site.socials.find((s) => s.kind === 'linkedin')?.href ?? '#',
    icon: 'lucide:linkedin',
  },
  {
    label: 'Email',
    href: site.socials.find((s) => s.kind === 'email')?.href ?? '#',
    icon: 'lucide:mail',
  },
];
---

<BaseLayout title="Contact — Alex Rivera">
  <h1 class="mb-2 text-3xl font-bold text-gray-900">Contact</h1>
  <p class="mb-10 max-w-prose text-gray-500">
    I'm most reachable via email or GitHub. No contact form — just direct links.
  </p>
  <ul class="flex flex-col gap-4">
    {
      contacts.map(({ label, href, icon }) => (
        <li>
          <a
            href={href}
            target={href.startsWith('mailto:') ? undefined : '_blank'}
            rel={href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
            class="inline-flex items-center gap-3 rounded-xl border border-gray-200 bg-white px-5 py-3 font-medium text-gray-700 shadow-sm transition-all hover:border-accent hover:text-accent hover:shadow-md"
          >
            <Icon name={icon} class="h-5 w-5" />
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
