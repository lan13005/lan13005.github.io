---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('experience');
const sorted = entries.sort(
  (a, b) => (b.data.end ?? new Date()).valueOf() - (a.data.end ?? new Date()).valueOf()
);
---

<BaseLayout title="Experience — Alex Rivera">
  <h1 class="mb-2 text-3xl font-bold text-gray-900">Experience</h1>
  <p class="mb-10 text-gray-500">Where I've worked and what I've done.</p>
  <div>
    {
      sorted.map((e) => (
        <ExperienceItem
          role={e.data.role}
          org={e.data.org}
          location={e.data.location}
          start={e.data.start}
          end={e.data.end}
          summary={e.data.summary}
          tags={e.data.tags}
        />
      ))
    }
  </div>
</BaseLayout>
