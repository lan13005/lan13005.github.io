---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatIDoCard from '../components/WhatIDoCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ExperienceItem from '../components/ExperienceItem.astro';
import { Icon } from 'astro-icon/components';
import { site, getFeaturedProjects, experience, sortProjects } from '../data/index';

const featured = getFeaturedProjects();

const sorted = [...experience].sort(
  (a, b) => (b.end ?? new Date()).valueOf() - (a.end ?? new Date()).valueOf()
);

const toc = sorted.map((e) => ({
  id: e.id,
  label: e.org,
  projects: sortProjects(e.project ?? []).map((p) => ({
    id: `${e.id}-${p.id}`,
    label: p.title,
  })),
}));

const iconMap: Record<string, string> = {
  github: 'lucide:github',
  linkedin: 'lucide:linkedin',
  scholar: 'lucide:graduation-cap',
  email: 'lucide:mail',
};

const contacts = site.social.filter((s) => ['github', 'linkedin', 'email'].includes(s.kind));
---

<BaseLayout>
  <!-- ── About ─────────────────────────────────────────────── -->
  <section id="about" class="mb-24 scroll-mt-8">
    <div class="mb-16 flex flex-col gap-10 md:flex-row md:items-center">
      <div class="min-w-0 flex-1">
        <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-accent">Welcome</p>
        <h1 class="mb-4 text-4xl font-bold text-gray-900 md:text-5xl">{site.greeting}</h1>
        <p class="mb-4 text-xl font-medium text-gray-500">{site.tagline}</p>
        <p class="mb-8 max-w-prose leading-relaxed text-gray-600">{site.bio}</p>
        <div class="flex flex-wrap gap-3">
          {
            site.cta.map((c) => (
              <a
                href={c.href}
                class:list={[
                  'rounded-xl px-5 py-2.5 text-sm font-medium shadow-sm transition-colors',
                  c.primary
                    ? 'bg-accent text-white hover:bg-accent-600'
                    : 'border border-gray-300 text-gray-700 hover:bg-gray-50',
                ]}
              >
                {c.label}
              </a>
            ))
          }
        </div>
      </div>
      <div class="flex shrink-0 justify-center md:justify-end">
        <img
          src="/avatar.png"
          alt="Profile photo"
          class="h-60 w-60 rounded-full object-cover shadow-lg ring-4 ring-accent-100"
        />
      </div>
    </div>

    <div class="mb-16">
      <h2 class="mb-6 text-2xl font-bold text-gray-900">What I Do</h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        {
          site.what_i_do.map((card) => (
            <WhatIDoCard icon={card.icon} title={card.title} blurb={card.blurb} />
          ))
        }
      </div>
    </div>

    {
      featured.length > 0 && (
        <div>
          <div class="mb-6 flex items-center justify-between">
            <h2 class="text-2xl font-bold text-gray-900">Featured Projects</h2>
            <a href="#experience" class="text-sm font-medium text-accent hover:underline">
              View all →
            </a>
          </div>
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            {featured.map((p) => (
              <ProjectCard
                title={p.title}
                summary={p.summary.web}
                tags={p.tags}
                href={`/projects/${p.id}`}
                repo={p.github}
                featured={true}
              />
            ))}
          </div>
        </div>
      )
    }
  </section>

  <!-- ── Experience ─────────────────────────────────────────── -->
  <section id="experience" class="mb-24 scroll-mt-8">
    <div class="flex gap-10 xl:gap-14">
      <div class="min-w-0 flex-1">
        <h2 class="mb-2 text-3xl font-bold text-gray-900">Experience</h2>
        <p class="mb-10 text-gray-500">Where I've worked and what I've built.</p>
        <div id="exp-list" class="relative">
          {
            sorted.map((e) => (
              <ExperienceItem
                id={e.id}
                role={e.role}
                org={e.org}
                location={e.location}
                start={e.start}
                end={e.end}
                summary={e.summary.web}
                tags={e.tags}
                projects={e.project}
              />
            ))
          }
          <svg
            id="exp-svg"
            class="pointer-events-none absolute left-0 top-0 z-0 overflow-visible"
            width="48"
            height="100"
            aria-hidden="true"></svg>
        </div>
      </div>

      <aside class="hidden w-44 shrink-0 lg:block">
        <nav class="sticky top-16" aria-label="Experience outline">
          <p class="mb-3 text-[10px] font-semibold uppercase tracking-widest text-gray-400">
            On this page
          </p>
          <ul class="flex flex-col gap-0.5 text-xs">
            {
              toc.map((section) => (
                <li>
                  <a
                    href={`#${section.id}`}
                    class="block truncate rounded py-1 font-medium text-gray-600 transition-colors hover:text-accent"
                    title={section.label}
                  >
                    {section.label}
                  </a>
                  {section.projects.length > 0 && (
                    <ul class="ml-3 flex flex-col gap-0.5">
                      {section.projects.map((p) => (
                        <li>
                          <a
                            href={`#${p.id}`}
                            class="block truncate rounded py-0.5 text-gray-400 transition-colors hover:text-accent"
                            title={p.label}
                          >
                            {p.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))
            }
          </ul>
        </nav>
      </aside>
    </div>
  </section>

  <!-- ── Activities ─────────────────────────────────────────── -->
  <section id="activities" class="mb-24 scroll-mt-8">
    <h2 class="mb-2 text-3xl font-bold text-gray-900">Activities &amp; Interests</h2>
    <p class="mb-10 text-gray-500">What I get up to outside of work.</p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        site.activity.map(({ icon, title, blurb, note }) => (
          <div class="flex flex-col gap-3 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-3">
              <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent-50 text-accent">
                <Icon name={icon} class="h-5 w-5" />
              </span>
              <h3 class="text-base font-semibold text-gray-900">{title}</h3>
            </div>
            <p class="text-sm leading-relaxed text-gray-600">{blurb}</p>
            {note && (
              <p class="mt-auto rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-700">
                {note}
              </p>
            )}
          </div>
        ))
      }
    </div>
  </section>

  <!-- ── Contact ────────────────────────────────────────────── -->
  <section id="contact" class="scroll-mt-8">
    <h2 class="mb-2 text-3xl font-bold text-gray-900">Contact</h2>
    <p class="mb-3 max-w-prose text-gray-500">You can reach me at:</p>
    <ul class="flex flex-row flex-wrap gap-4">
      {
        contacts.map((s) => (
          <li>
            <a
              href={s.href}
              target={s.kind !== 'email' ? '_blank' : undefined}
              rel={s.kind !== 'email' ? 'noopener noreferrer' : undefined}
              class="inline-flex items-center gap-3 rounded-xl border border-gray-200 bg-white px-5 py-3 font-medium text-gray-700 shadow-sm transition-all hover:border-accent hover:text-accent hover:shadow-md"
            >
              <Icon name={iconMap[s.kind] ?? 'lucide:link'} class="h-5 w-5" />
              {s.label}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<script>
  const sections = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');

  const activeClasses = ['bg-accent-50', 'font-semibold', 'text-accent'];
  const inactiveClasses = ['text-gray-600'];

  function setActive(id: string) {
    navLinks.forEach((link) => {
      const isActive = link.getAttribute('data-nav-link') === id;
      link.classList.toggle('bg-accent-50', isActive);
      link.classList.toggle('font-semibold', isActive);
      link.classList.toggle('text-accent', isActive);
      link.classList.toggle('text-gray-600', !isActive);
    });
    history.replaceState(null, '', id === 'about' ? '/' : `#${id}`);
  }

  function updateActive() {
    const threshold = window.scrollY + window.innerHeight * 0.25;
    let active = sections[0];
    for (const section of sections) {
      if (section.offsetTop <= threshold) active = section;
    }
    if (active) setActive(active.id);
  }

  // Intercept nav link clicks: smooth-scroll when on same page,
  // fall through to href="/#section" navigation when on another page.
  document.addEventListener('click', (e) => {
    const anchor = (e.target as Element).closest<HTMLAnchorElement>('[data-nav-link]');
    if (!anchor) return;
    const id = anchor.getAttribute('data-nav-link')!;
    const target = document.getElementById(id);
    if (!target) return; // not on this page — let the href navigate normally
    e.preventDefault();
    target.scrollIntoView({ behavior: 'smooth' });
    history.replaceState(null, '', id === 'about' ? '/' : `#${id}`);
    setActive(id);
  });

  window.addEventListener('scroll', updateActive, { passive: true });
  requestAnimationFrame(updateActive);

  // ── Timeline SVG ──────────────────────────────────────────────────────────
  const ACCENT = '#6366f1';
  const MAIN_X = 0;
  const INDENT_X = 20;

  function drawTimeline() {
    const list = document.getElementById('exp-list');
    const svg = document.getElementById('exp-svg') as SVGSVGElement | null;
    if (!list || !svg) return;

    const listRect = list.getBoundingClientRect();
    const totalHeight = list.offsetHeight;

    svg.setAttribute('height', String(totalHeight));

    // Clear previous render
    while (svg.firstChild) svg.removeChild(svg.firstChild);

    const expItems = Array.from(list.querySelectorAll<HTMLElement>('[data-exp-item]'));
    if (expItems.length === 0) return;

    // Main vertical rail
    const rail = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    rail.setAttribute('x1', String(MAIN_X));
    rail.setAttribute('y1', '0');
    rail.setAttribute('x2', String(MAIN_X));
    rail.setAttribute('y2', String(totalHeight));
    rail.setAttribute('stroke', '#d1d5db');
    rail.setAttribute('stroke-width', '2');
    rail.setAttribute('stroke-linecap', 'round');
    svg.appendChild(rail);

    expItems.forEach((expItem) => {
      const itemRect = expItem.getBoundingClientRect();
      const expDotY = itemRect.top - listRect.top + 6;

      const projItems = Array.from(expItem.querySelectorAll<HTMLElement>('[data-proj-item]'));

      projItems.forEach((projItem) => {
        const projY = projItem.getBoundingClientRect().top - listRect.top + 20;

        // Short horizontal connector
        const connector = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        connector.setAttribute('x1', String(MAIN_X));
        connector.setAttribute('y1', String(projY));
        connector.setAttribute('x2', String(INDENT_X));
        connector.setAttribute('y2', String(projY));
        connector.setAttribute('stroke', '#d1d5db');
        connector.setAttribute('stroke-width', '1.5');
        connector.setAttribute('stroke-linecap', 'round');
        svg.appendChild(connector);

        // Project dot
        const projDot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        projDot.setAttribute('cx', String(INDENT_X));
        projDot.setAttribute('cy', String(projY));
        projDot.setAttribute('r', '4');
        projDot.setAttribute('fill', 'white');
        projDot.setAttribute('stroke', ACCENT);
        projDot.setAttribute('stroke-width', '2');
        projDot.setAttribute('opacity', '0.75');
        svg.appendChild(projDot);
      });
    });
  }

  requestAnimationFrame(drawTimeline);

  let _tlResizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(_tlResizeTimer);
    _tlResizeTimer = setTimeout(drawTimeline, 100);
  });
</script>
