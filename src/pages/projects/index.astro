---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { site, getAllProjects } from '../../data/index';

const projects = getAllProjects();
---

<BaseLayout title={`Projects — ${site.name}`}>
  <h1 class="mb-2 text-3xl font-bold text-gray-900">Projects</h1>
  <p class="mb-10 text-gray-500">Things I've built and researched.</p>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {
      projects.map((p) => (
        <ProjectCard
          title={p.title}
          summary={p.summary.web}
          tags={p.tags}
          href={`/projects/${p.id}`}
          repo={p.github}
          featured={p.featured}
        />
      ))
    }
  </div>
</BaseLayout>
