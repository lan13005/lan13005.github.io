---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatIDoCard from '../components/WhatIDoCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { site, getFeaturedProjects } from '../data/index';

const featured = getFeaturedProjects();
---

<BaseLayout>
  <!-- Hero -->
  <section class="mb-16 flex flex-col gap-10 md:flex-row md:items-center">
    <div class="min-w-0 flex-1">
      <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-accent">Welcome</p>
      <h1 class="mb-4 text-4xl font-bold text-gray-900 md:text-5xl">{site.greeting}</h1>
      <p class="mb-4 text-xl font-medium text-gray-500">{site.tagline}</p>
      <p class="mb-8 max-w-prose leading-relaxed text-gray-600">{site.bio}</p>
      <div class="flex flex-wrap gap-3">
        {
          site.cta.map((c) => (
            <a
              href={c.href}
              class:list={[
                'rounded-xl px-5 py-2.5 text-sm font-medium shadow-sm transition-colors',
                c.primary
                  ? 'bg-accent text-white hover:bg-accent-600'
                  : 'border border-gray-300 text-gray-700 hover:bg-gray-50',
              ]}
            >
              {c.label}
            </a>
          ))
        }
      </div>
    </div>
    <!-- Profile photo -->
    <div class="flex shrink-0 justify-center md:justify-end">
      <img
        src="/avatar.png"
        alt="Profile photo"
        class="h-60 w-60 rounded-full object-cover shadow-lg ring-4 ring-accent-100"
      />
    </div>
  </section>

  <!-- What I Do -->
  <section class="mb-16">
    <h2 class="mb-6 text-2xl font-bold text-gray-900">What I Do</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      {
        site.what_i_do.map((card) => (
          <WhatIDoCard icon={card.icon} title={card.title} blurb={card.blurb} />
        ))
      }
    </div>
  </section>

  <!-- Featured Projects -->
  {
    featured.length > 0 && (
      <section>
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-2xl font-bold text-gray-900">Featured Projects</h2>
          <a href="/projects" class="text-sm font-medium text-accent hover:underline">
            View all →
          </a>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {featured.map((p) => (
            <ProjectCard
              title={p.title}
              summary={p.summary.web}
              tags={p.tags}
              href={`/projects/${p.id}`}
              repo={p.github}
              featured={true}
            />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
