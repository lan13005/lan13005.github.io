---
import { Icon } from 'astro-icon/components';

interface Props {
  icon: string;
  title: string;
  blurb: string;
}
const { icon, title, blurb } = Astro.props;
---

<div
  class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow duration-200 hover:shadow-md"
>
  <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent-50">
    <Icon name={icon} class="h-5 w-5 text-accent" />
  </div>
  <h3 class="mb-1 text-base font-semibold text-gray-900">{title}</h3>
  <p class="text-sm leading-relaxed text-gray-600">{blurb}</p>
</div>
