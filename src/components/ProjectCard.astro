---
interface Props {
  title: string;
  summary: string;
  tags: string[];
  href: string;
  repo?: string;
  featured?: boolean;
}
const { title, summary, tags, href, repo, featured } = Astro.props;
---

<article
  class="flex flex-col gap-4 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow duration-200 hover:shadow-md"
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-base font-semibold leading-snug text-gray-900">
      <a href={href} class="transition-colors hover:text-accent">
        {title}
      </a>
    </h3>
    {
      featured && (
        <span class="shrink-0 rounded-full bg-accent-50 px-2 py-0.5 text-xs font-medium text-accent">
          Featured
        </span>
      )
    }
  </div>
  <p class="flex-1 text-sm leading-relaxed text-gray-600">{summary}</p>
  <div class="flex flex-wrap items-center justify-between gap-2">
    <div class="flex flex-wrap gap-1.5">
      {
        tags.map((tag) => (
          <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600">{tag}</span>
        ))
      }
    </div>
    {
      repo && (
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-medium text-accent hover:underline"
        >
          GitHub →
        </a>
      )
    }
  </div>
</article>
