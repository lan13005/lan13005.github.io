---
import type { Project } from '../data/index';
import { sortProjects, getTimelineDate } from '../data/index';

interface Props {
  id: string;
  role: string;
  org: string;
  location?: string;
  start: Date;
  end?: Date;
  summary: string;
  tags: string[];
  projects?: Project[];
}
const { id, role, org, location, start, end, summary, tags, projects } = Astro.props;

const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
const startStr = fmt(start);
const endStr = end ? fmt(end) : 'Present';

const sorted = sortProjects(projects ?? []);
---

<div class="relative pb-10 pl-8 last:pb-0">
  <div class="absolute bottom-0 left-0 top-0 w-px bg-gray-200" aria-hidden="true"></div>
  <div
    class="absolute left-0 top-1.5 h-3 w-3 -translate-x-1/2 rounded-full border-2 border-white bg-accent shadow"
    aria-hidden="true"
  >
  </div>

  <div class="flex flex-col gap-1">
    <p class="text-xs font-medium uppercase tracking-wide text-gray-400">
      {startStr} — {endStr}
    </p>
    <h3 id={id} class="text-base font-semibold text-gray-900">{role}</h3>
    <p class="text-sm text-gray-500">{org}{location ? ` · ${location}` : ''}</p>
    <p class="mt-2 text-sm leading-relaxed text-gray-600">{summary}</p>
    <div class="mt-3 flex flex-wrap gap-1.5">
      {
        tags.map((tag) => (
          <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600">{tag}</span>
        ))
      }
    </div>

    {
      sorted.length > 0 && (
        <ul class="mt-4 flex flex-col gap-3">
          {sorted.map((p) => {
            const tlDate = getTimelineDate(p);
            return (
              <li
                id={`${id}-${p.id}`}
                class="relative rounded-xl border border-gray-100 bg-gray-50 px-4 py-3"
              >
                {tlDate && (
                  <>
                    {/* Horizontal connector from timeline to card left edge */}
                    <div
                      class="pointer-events-none absolute -left-8 top-5 h-px w-8 bg-gray-300"
                      aria-hidden="true"
                    />
                    {/* Dot centred on the timeline line */}
                    <div
                      class="pointer-events-none absolute -left-8 top-5 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent/60 ring-2 ring-white"
                      aria-hidden="true"
                    />
                  </>
                )}

                <div class="flex items-start justify-between gap-3">
                  <a
                    href={`/projects/${p.id}`}
                    class="text-sm font-medium text-gray-900 transition-colors hover:text-accent"
                  >
                    {p.title}
                  </a>
                  {p.github && (
                    <a
                      href={p.github}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="shrink-0 text-xs font-medium text-accent hover:underline"
                    >
                      GitHub →
                    </a>
                  )}
                </div>

                {/* Date range row */}
                {(p.start || p.end) && (
                  <p class="mt-0.5 text-[10px] uppercase tracking-wide text-gray-400">
                    {p.start ? fmt(p.start) : '?'}
                    {' — '}
                    {p.end ? fmt(p.end) : 'Present'}
                    {tlDate && p.timeline_label && (
                      <span class="ml-1.5 font-semibold text-accent/70">
                        · {p.timeline_label}
                      </span>
                    )}
                  </p>
                )}

                <p class="mt-1 text-xs leading-relaxed text-gray-500">{p.summary.web}</p>
                <div class="mt-2 flex flex-wrap gap-1">
                  {p.tags.map((t) => (
                    <span class="rounded-full bg-white px-2 py-0.5 text-xs text-gray-500 ring-1 ring-gray-200">
                      {t}
                    </span>
                  ))}
                </div>
              </li>
            );
          })}
        </ul>
      )
    }
  </div>
</div>
