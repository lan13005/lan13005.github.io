---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { site } from '../data/index';

const iconMap: Record<string, string> = {
  github: 'lucide:github',
  linkedin: 'lucide:linkedin',
  scholar: 'lucide:graduation-cap',
  email: 'lucide:mail',
};

const contacts = site.social.filter((s) => ['github', 'linkedin', 'email'].includes(s.kind));
---

<BaseLayout title={`Contact — ${site.name}`}>
  <h1 class="mb-2 text-3xl font-bold text-gray-900">Contact</h1>
  <p class="mb-10 max-w-prose text-gray-500">
    I'm most reachable via email or GitHub. No contact form — just direct links.
  </p>
  <ul class="flex flex-col gap-4">
    {
      contacts.map((s) => (
        <li>
          <a
            href={s.href}
            target={s.kind !== 'email' ? '_blank' : undefined}
            rel={s.kind !== 'email' ? 'noopener noreferrer' : undefined}
            class="inline-flex items-center gap-3 rounded-xl border border-gray-200 bg-white px-5 py-3 font-medium text-gray-700 shadow-sm transition-all hover:border-accent hover:text-accent hover:shadow-md"
          >
            <Icon name={iconMap[s.kind] ?? 'lucide:link'} class="h-5 w-5" />
            {s.label}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
