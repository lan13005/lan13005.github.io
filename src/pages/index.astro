---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatIDoCard from '../components/WhatIDoCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { site } from '../config';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<BaseLayout>
  <!-- Hero -->
  <section class="mb-16 flex flex-col gap-10 md:flex-row md:items-center">
    <div class="min-w-0 flex-1">
      <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-accent">Welcome</p>
      <h1 class="mb-4 text-4xl font-bold text-gray-900 md:text-5xl">{site.greeting}</h1>
      <p class="mb-4 text-xl font-medium text-gray-500">{site.tagline}</p>
      <p class="mb-8 max-w-prose leading-relaxed text-gray-600">{site.bio}</p>
      <div class="flex flex-wrap gap-3">
        <a
          href={site.ctas.primary.href}
          class="rounded-xl bg-accent px-5 py-2.5 text-sm font-medium text-white shadow-sm transition-colors hover:bg-accent-600"
        >
          {site.ctas.primary.label}
        </a>
        <a
          href={site.ctas.secondary.href}
          class="rounded-xl border border-gray-300 px-5 py-2.5 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-50"
        >
          {site.ctas.secondary.label}
        </a>
      </div>
    </div>
    <!-- Profile photo -->
    <div class="flex shrink-0 justify-center md:justify-end">
      <img
        src="/avatar.png"
        alt="Profile photo"
        class="h-60 w-60 rounded-full object-cover shadow-lg ring-4 ring-accent-100"
      />
    </div>
  </section>

  <!-- What I Do -->
  <section class="mb-16">
    <h2 class="mb-6 text-2xl font-bold text-gray-900">What I Do</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      {
        site.whatIDo.map((card) => (
          <WhatIDoCard icon={card.icon} title={card.title} blurb={card.blurb} />
        ))
      }
    </div>
  </section>

  <!-- Recent Projects teaser -->
  {
    featured.length > 0 && (
      <section>
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-2xl font-bold text-gray-900">Recent Projects</h2>
          <a href="/projects" class="text-sm font-medium text-accent hover:underline">
            View all →
          </a>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {featured.map((p) => (
            <ProjectCard
              title={p.data.title}
              summary={p.data.summary}
              tags={p.data.tags}
              href={`/projects/${p.slug}`}
              repo={p.data.repo}
              featured={p.data.featured}
            />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
